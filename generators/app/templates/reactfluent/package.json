    },
    "devDependencies": {
        "@pptb/types": "^1.2.0",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.3.4",
        "typescript": "^5.6.3",
        "vite": "^7.1.11"
    },
    "files": [
        "dist",
        "npm-shrinkwrap.json"
    ]
}
